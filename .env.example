# ==============================================================================
# Deep Research MCP Server - Production Configuration
# ==============================================================================
#
# Uses OpenRouter API for deep research with Perplexity Sonar models
# Copy this file to .env and configure with your actual values
# NEVER commit the .env file to version control!

# ==============================================================================
# REQUIRED: API CONFIGURATION
# ==============================================================================

# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# OpenRouter API Base URL
# Default: https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use for deep research
# Default: perplexity/sonar-deep-research
# Other options: perplexity/sonar-pro, perplexity/sonar
RESEARCH_MODEL=perplexity/sonar-deep-research

# ==============================================================================
# OPTIONAL: RESEARCH PARAMETERS
# ==============================================================================

# API timeout in milliseconds (default: 30 minutes for deep research)
API_TIMEOUT_MS=1800000

# Default reasoning effort level (low, medium, high)
DEFAULT_REASONING_EFFORT=high

# Default budget tokens for research
DEFAULT_BUDGET_TOKENS=100000

# Default max attempts for research
DEFAULT_MAX_ATTEMPTS=3

# Default team size for parallel research
DEFAULT_TEAM_SIZE=5

# Default max returned URLs
DEFAULT_MAX_URLS=100

# ==============================================================================
# OPTIONAL: MCP SERVER CONFIGURATION
# ==============================================================================

# Server name for MCP protocol
MCP_SERVER_NAME=perplexity.deepresearch.core

# Server version
MCP_SERVER_VERSION=2.0.0

# Enable debug logging (true/false)
MCP_DEBUG=false

# Node.js environment
NODE_ENV=production

# ==============================================================================
# OPTIONAL: TOOL CONFIGURATION
# ==============================================================================

# Path to tools YAML configuration (relative to project root)
TOOLS_CONFIG_PATH=config/tools.yaml

# ==============================================================================
# WEB SCRAPING & SEARCH TOOLS
# ==============================================================================

# Scrape.do API Key (for scrape_links tool)
# Get from: https://scrape.do/dashboard
SCRAPEDO_API_KEY=your-scrape-do-api-key-here

# SERPER API Key (for search_multiple tool)
# Get from: https://serper.dev/api-key
SERPER_API_KEY=your-serper-api-key-here

# ==============================================================================
# LLM CONTENT EXTRACTION (OPTIONAL)
# ==============================================================================

# OpenAI-compatible API Key for content post-processing
# Use OpenRouter for multi-model support: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key

# OpenRouter API Base URL
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Primary LLM model for content extraction
OPENAI_MODEL=openai/gpt-oss-120b:nitro

# Secondary failover model
OPENAI_MODEL_SECONDARY=google/gemini-2.5-flash

# Tertiary failover model
OPENAI_MODEL_TERTIARY=openai/gpt-oss-20b:free

# Enable LLM processing by default (true/false)
LLM_ENABLED=true

# LLM timeout in milliseconds
LLM_TIMEOUT_MS=300000

# Maximum concurrent LLM requests
LLM_MAX_CONCURRENT=5

# Maximum LLM retry attempts
LLM_MAX_RETRIES=3

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
#
# 1. NEVER hardcode API keys in source code
# 2. Always use environment variables for sensitive data
# 3. Keep .env file in .gitignore
# 4. Use different keys for development/staging/production
# 5. Rotate API keys regularly
# 6. Monitor API usage and costs
#
# ==============================================================================
# CLAUDE CODE INTEGRATION
# ==============================================================================
#
# Add this MCP server to your Claude Code configuration:
#
# For ~/.config/claude/claude_desktop_config.json:
# {
#   "mcpServers": {
#     "perplexity-deepresearch": {
#       "command": "node",
#       "args": ["/absolute/path/to/deep-research-bug-fix-mcp/dist/index.js"],
#       "env": {
#         "OPENROUTER_API_KEY": "sk-or-v1-your-api-key-here"
#       }
#     }
#   }
# }
#
# ==============================================================================