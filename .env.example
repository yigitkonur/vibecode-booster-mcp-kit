# JINA DeepSearch MCP Server Environment Configuration
#
# Copy this file to .env and add your actual values
# Never commit the actual .env file to version control

# ==============================================================================
# REQUIRED: JINA API AUTHENTICATION
# ==============================================================================

# Your JINA API key - get it from https://jina.ai/
JINA_API_KEY=your_jina_api_key_here

# ==============================================================================
# OPTIONAL: MCP SERVER CONFIGURATION
# ==============================================================================

# Enable debug logging for MCP operations
# Set to true to see debug output in stderr
MCP_DEBUG=false

# Node.js environment
NODE_ENV=development

# ==============================================================================
# SECURITY NOTES
# ==============================================================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual JINA API key in .env
# 3. The .env file is already in .gitignore to prevent committing secrets
# 4. Get your JINA API key from: https://jina.ai/

# ==============================================================================
# CLAUDE CODE INTEGRATION
# ==============================================================================

# Add this MCP server to your Claude Code .mcp.json:
# {
#   "mcpServers": {
#     "jina-deepsearch": {
#       "command": "node",
#       "args": ["/absolute/path/to/jina-deepsearch-mcp/dist/index.js"],
#       "env": {
#         "JINA_API_KEY": "your_jina_api_key_here"
#       }
#     }
#   }
# }