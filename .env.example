# Perplexity Deep Research MCP Server Environment Configuration
#
# Copy this file to .env and add your actual values
# Never commit the actual .env file to version control

# ==============================================================================
# NOTE: API KEY IS HARDCODED IN CONSTANTS
# ==============================================================================

# The OpenRouter API key for Perplexity Sonar Deep Research is hardcoded
# in src/utils/constants.ts for simplicity. No environment variable needed.

# ==============================================================================
# OPTIONAL: MCP SERVER CONFIGURATION
# ==============================================================================

# Enable debug logging for MCP operations
# Set to true to see debug output in stderr
MCP_DEBUG=false

# Node.js environment
NODE_ENV=development

# ==============================================================================
# CLAUDE CODE INTEGRATION
# ==============================================================================

# Add this MCP server to your Claude Code .mcp.json:
# {
#   "mcpServers": {
#     "perplexity-deepresearch": {
#       "command": "node",
#       "args": ["/absolute/path/to/deep-research-bug-fix-mcp/dist/index.js"]
#     }
#   }
# }