# TEMPLATE: Environment Variables Configuration
#
# CUSTOMIZATION GUIDE:
# 1. Replace {{SERVICE_NAME}} with your service name
# 2. Update {{API_TOKEN_NAME}} with your service's token/key name
# 3. Add any additional environment variables your service needs
# 4. Copy this file to .env and add your actual values
#
# TUTORIAL: Environment Variables in MCP Servers
#
# Environment variables are essential for:
# - API authentication (tokens, keys, secrets)
# - Configuration that varies between environments
# - Sensitive data that shouldn't be in code
# - Feature flags and debugging options
#
# Security Best Practices:
# - Never commit .env files with real values to version control
# - Use .env.example (this file) to document required variables
# - Validate all required environment variables at startup
# - Use different .env files for development, staging, production

# ==============================================================================
# API AUTHENTICATION
# ==============================================================================

# TODO: Replace with your service's API token/key variable name
# Examples for different services:
# - OpenAI: OPENAI_API_KEY=your_openai_api_key_here
# - Stripe: STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
# - GitHub: GITHUB_TOKEN=ghp_your_github_token_here
# - Anthropic: ANTHROPIC_API_KEY=your_anthropic_key_here

{{API_TOKEN_NAME}}=your_{{service_name}}_api_token_here

# Alternative authentication patterns (uncomment if needed):
# {{SERVICE_NAME}}_API_SECRET=your_api_secret_here
# {{SERVICE_NAME}}_CLIENT_ID=your_client_id_here
# {{SERVICE_NAME}}_CLIENT_SECRET=your_client_secret_here

# ==============================================================================
# API CONFIGURATION
# ==============================================================================

# API Base URL (if configurable)
# {{SERVICE_NAME}}_BASE_URL=https://api.{{service-domain}}.com

# API Version (if your service supports versioning)
# {{SERVICE_NAME}}_API_VERSION=v1

# Regional/Environment Configuration
# {{SERVICE_NAME}}_REGION=us-east-1
# {{SERVICE_NAME}}_ENVIRONMENT=production

# ==============================================================================
# RATE LIMITING & PERFORMANCE
# ==============================================================================

# Request timeout in milliseconds
# {{SERVICE_NAME}}_TIMEOUT=30000

# Maximum concurrent requests
# {{SERVICE_NAME}}_MAX_CONCURRENT=5

# Rate limiting (requests per minute/hour)
# {{SERVICE_NAME}}_RATE_LIMIT_PER_MINUTE=60
# {{SERVICE_NAME}}_RATE_LIMIT_PER_HOUR=1000

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

# Enable/disable specific features
# {{SERVICE_NAME}}_ENABLE_CACHING=true
# {{SERVICE_NAME}}_ENABLE_ANALYTICS=false
# {{SERVICE_NAME}}_ENABLE_DEBUG_LOGGING=false

# Quality/performance settings
# {{SERVICE_NAME}}_DEFAULT_QUALITY=standard
# {{SERVICE_NAME}}_MAX_RETRIES=3

# ==============================================================================
# MCP SERVER CONFIGURATION
# ==============================================================================

# Enable debug logging for MCP operations
# Set to any truthy value to enable debug output to stderr
MCP_DEBUG=false

# Server configuration
# MCP_SERVER_NAME=mcp-{{service-name}}
# MCP_SERVER_VERSION=1.0.0

# ==============================================================================
# DEVELOPMENT & DEBUGGING
# ==============================================================================

# Node.js environment
NODE_ENV=development

# Logging levels
# LOG_LEVEL=info

# Development-specific settings
# DEV_MODE=true
# MOCK_API_RESPONSES=false

# ==============================================================================
# EXAMPLES FOR COMMON SERVICES
# ==============================================================================

# OpenAI Configuration Example:
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_ORG_ID=org-your_organization_id
# OPENAI_DEFAULT_MODEL=gpt-3.5-turbo
# OPENAI_MAX_TOKENS=1000

# Stripe Configuration Example:
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# GitHub Configuration Example:
# GITHUB_TOKEN=ghp_your_github_personal_access_token_here
# GITHUB_ORG=your_organization_name
# GITHUB_RATE_LIMIT_PER_HOUR=5000

# Database Configuration Example (if needed):
# DATABASE_URL=postgresql://user:password@localhost:5432/database
# REDIS_URL=redis://localhost:6379

# ==============================================================================
# SECURITY NOTES
# ==============================================================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. Add .env to .gitignore to prevent committing secrets
# 4. Use environment-specific files for different deployments:
#    - .env.development
#    - .env.staging
#    - .env.production
# 5. Consider using a secrets management service for production